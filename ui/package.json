{
  "name": "git-scripts-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"node server.mjs\" \"rescript build -w\" \"vite\"",
    "dev:api": "node server.mjs",
    "dev:ui": "rescript build -w",
    "build": "rescript build && vite build",
    "check": "rescript build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@rescript/core": "^1.6.1",
    "@rescript/runtime": "^12.0.0",
    "rescript-tea": "file:../../rescript-tea"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "rescript": "^12.0.0",
    "vite": "^8.0.8"
  }
}
