#!/usr/bin/env bash
# SPDX-License-Identifier: PMPL-1.0-or-later
#
# Git Scripts Launcher - Standardized launcher following UX standards
# D-SIP-FV-MA Compliant: Dependable, Secure, Interoperable, Performant,
# Functional, Versatile, Metaiconic, Accessible

set -euo pipefail

# ============================================================================
# CONFIGURATION
# ============================================================================
APP_NAME="GitScripts"
VERSION="1.0.0"
REPO_DIR="/var/mnt/eclipse/repos/git-scripts"
COMMAND="./script_manager"
URL=""  # No web URL for this CLI application
PID_FILE="/tmp/${APP_NAME,,}-server.pid"
LOG_FILE="/tmp/${APP_NAME,,}-server.log"
MODE="${1:---auto}"
DESKTOP_FILE="$REPO_DIR/git-scripts.desktop"

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'  # No Color

# ============================================================================
# UTILITY FUNCTIONS
# ============================================================================

log() {
  echo "[$APP_NAME] $1"
}

err() {
  echo "[$APP_NAME] ERROR: $1" >&2
}

warn() {
  echo "[$APP_NAME] WARNING: $1" >&2
}

is_running() {
  [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

wait_for_process() {
  local max_wait=$1
  local waited=0
  
  while [ $waited -lt $max_wait ]; do
    if is_running; then
      return 0
    fi
    sleep 1
    waited=$((waited + 1))
  done
  
  return 1
}

start_server() {
  if is_running; then
    log "Git Scripts is already running (PID: $(cat "$PID_FILE"))"
    return 0
  fi
  
  log "Starting Git Scripts TUI..."
  
  # Start in background with nohup to prevent process from being killed
  cd "$REPO_DIR"
  nohup $COMMAND >"$LOG_FILE" 2>&1 &
  echo $! > "$PID_FILE"
  
  # Wait for process to start
  if ! wait_for_process 10; then
    err "Git Scripts did not start within 10 seconds"
    err "Check log: $LOG_FILE"
    err ""
    err "Troubleshooting steps:"
    err "  1. Check if script_manager exists: 'ls -la $REPO_DIR/script_manager'"
    err "  2. Review server logs: 'tail -50 $LOG_FILE'"
    err "  3. Verify Elixir dependencies: 'cd $REPO_DIR && mix deps.get'"
    err "  4. Rebuild escript: 'cd $REPO_DIR && mix escript.build'"
    err "  5. See documentation: https://github.com/hyperpolymath/git-scripts"
    
    return 1
  fi
  
  log "Git Scripts started successfully"
  log "Log file: $LOG_FILE"
  
  return 0
}

stop_server() {
  if ! is_running; then
    log "No running Git Scripts instance found"
    return 0
  fi
  
  log "Stopping Git Scripts..."
  kill "$(cat "$PID_FILE")" 2>/dev/null || true
  rm -f "$PID_FILE"
  log "Git Scripts stopped"
}

install_shortcuts() {
  log "Installing shortcuts for $APP_NAME..."
  
  # Detect platform
  local platform="unknown"
  if [ -d "/Applications" ] && [ "$OSTYPE" = "darwin*" ]; then
    platform="macos"
  elif [ -d "/mnt/c" ] || [ -n "${WINDIR:-}" ]; then
    platform="windows"
  else
    platform="linux"
  fi
  
  log "Detected platform: $platform"
  
  # Install for Linux (XDG compliant)
  if [ "$platform" = "linux" ]; then
    # User applications directory
    local user_apps="$HOME/.local/share/applications"
    mkdir -p "$user_apps"
    
    # Copy desktop file
    cp "$DESKTOP_FILE" "$user_apps/"
    chmod +x "$user_apps/git-scripts.desktop"
    
    # Update desktop database
    if command -v update-desktop-database >/dev/null 2>&1; then
      update-desktop-database "$user_apps" 2>/dev/null || true
    fi
    
    log "✅ Installed to user applications menu"
    log "   Location: $user_apps/git-scripts.desktop"
    
    # Optional: Create desktop shortcut
    local desktop_dir="$HOME/Desktop"
    if [ -d "$desktop_dir" ]; then
      cp "$DESKTOP_FILE" "$desktop_dir/"
      chmod +x "$desktop_dir/git-scripts.desktop"
      log "✅ Created desktop shortcut"
      log "   Location: $desktop_dir/git-scripts.desktop"
    fi
    
  # Install for macOS
  elif [ "$platform" = "macos" ]; then
    # Copy to Applications directory
    local apps_dir="$HOME/Applications"
    mkdir -p "$apps_dir"
    
    # Create .app bundle structure
    local app_bundle="$apps_dir/GitScripts.app"
    mkdir -p "$app_bundle/Contents/MacOS"
    mkdir -p "$app_bundle/Contents/Resources"
    
    # Copy launcher script
    cp "$0" "$app_bundle/Contents/MacOS/GitScripts"
    chmod +x "$app_bundle/Contents/MacOS/GitScripts"
    
    # Create Info.plist
    cat > "$app_bundle/Contents/Info.plist" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>GitScripts</string>
    <key>CFBundleIconFile</key>
    <string>icon.icns</string>
    <key>CFBundleIdentifier</key>
    <string>com.hyperpolymath.gitscripts</string>
    <key>CFBundleName</key>
    <string>GitScripts</string>
    <key>CFBundleVersion</key>
    <string>1.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>
</dict>
</plist>
EOF
    
    log "✅ Created macOS application bundle"
    log "   Location: $app_bundle"
    
  # Install for Windows (WSL or native)
  elif [ "$platform" = "windows" ]; then
    if [ -d "/mnt/c" ]; then
      # WSL environment
      local win_desktop="/mnt/c/Users/$USER/Desktop"
      if [ -d "$win_desktop" ]; then
        cp "$DESKTOP_FILE" "$win_desktop/"
        log "✅ Created Windows desktop shortcut (WSL)"
        log "   Location: $win_desktop/git-scripts.desktop"
      fi
      
      # Create Windows shortcut file
      local lnk_file="$win_desktop/Git Scripts.lnk"
      log "Note: For native Windows .lnk file, use Windows Explorer to create shortcut"
      log "      Target: wsl.exe /path/to/git-scripts-launcher"
    else
      log "⚠️  Windows detection without WSL mount points"
      log "   Manual installation recommended"
    fi
  fi
  
  log "✅ Shortcut installation complete!"
  log ""
  log "Next steps:"
  log "  - Linux: Application should appear in your menu"
  log "  - macOS: Drag GitScripts.app to Applications folder"
  log "  - Windows: Use the desktop shortcut or create .lnk file"
}

# ============================================================================
# HELP AND VERSION FUNCTIONS
# ============================================================================

show_help() {
  echo -e "${BLUE}${APP_NAME} ${VERSION}${NC}"
  echo -e "${GREEN}Usage:${NC} git-scripts-launcher [OPTION]"
  echo ""
  echo "Options:"
  echo "  --start       Start the Git Scripts TUI"
  echo "  --stop        Stop the running Git Scripts instance"
  echo "  --status      Show current status"
  echo "  --install     Install desktop shortcuts (Linux/macOS/Windows)"
  echo "  --auto        Start TUI (default)"
  echo "  --help        Show this help message"
  echo "  --version     Show version information"
  echo ""
  echo "Examples:"
  echo "  ./git-scripts-launcher --start"
  echo "  ./git-scripts-launcher --install"
  echo "  ./git-scripts-launcher --help"
}

show_version() {
  echo -e "${BLUE}${APP_NAME}${NC} version ${GREEN}${VERSION}${NC}"
  echo "Standardized launcher for Git Scripts management"
  echo "D-SIP-FV-MA Compliant: Dependable, Secure, Interoperable, Performant"
  echo "Copyright (c) 2026 hyperpolymath"
}

# ============================================================================
# MAIN SWITCH
# ============================================================================

case "$MODE" in
  --start)
    start_server
    ;;
  
  --stop)
    stop_server
    ;;
  
  --status)
    if is_running; then
      log "Git Scripts is running (PID: $(cat "$PID_FILE"))"
    else
      log "Git Scripts is not running"
    fi
    ;;
  
  --browser|--web)
    log "Git Scripts is a CLI application, no browser needed"
    start_server
    ;;
  
  --install)
    install_shortcuts
    ;;
  
  --help|-h|--?)
    show_help
    ;;
  
  --version|-v)
    show_version
    ;;
  
  --auto|*)
    start_server
    ;;
esac